# Alvioli Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (Required for enhanced AI features)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=
# Optional: OpenAI API Key (Alternative to Gemini)
# OPENAI_API_KEY=your_openai_api_key_here

# Application Settings
LOG_LEVEL=info
ENABLE_TELEMETRY=false
MAX_RETRIES=3
COMMAND_TIMEOUT=300000

# Browser Settings
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
DEFAULT_BROWSER=auto

# Terminal Settings
DEFAULT_SHELL=/bin/bash
ENFORCE_BASH_SHELL=true
PACKAGE_MANAGER_PREFERENCE=apt,snap,flatpak,pacman

# Security Settings
ALLOW_ROOT_COMMANDS=true
SAFE_MODE=false
BLOCKED_COMMANDS=rm -rf /,mkfs,dd if=/dev/zero

# Development Settings
DEBUG_MODE=false
VERBOSE_LOGGING=false