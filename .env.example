# Kira Autopilot Configuration
# Copy this file to .env and fill in your API keys

# Google Gemini API Key (REQUIRED - Kira will not work without this)
# Get your FREE API key from Google AI Studio:
# 👉 https://aistudio.google.com/app/apikey
# 👉 https://makersuite.google.com/app/apikey (alternative)
# 
# Quick setup:
# 1. Visit: https://aistudio.google.com/app/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key"
# 4. Copy and paste the key below
#
# The Gemini API is FREE with generous limits:
# • 15 requests per minute
# • 1 million tokens per minute  
# • 1,500 requests per day
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
LOG_LEVEL=info
ENABLE_TELEMETRY=false
MAX_RETRIES=3
COMMAND_TIMEOUT=300000

# Browser Settings
BROWSER_HEADLESS=false
BROWSER_TIMEOUT=30000
DEFAULT_BROWSER=auto

# Terminal Settings
DEFAULT_SHELL=/bin/bash
ENFORCE_BASH_SHELL=true
# Package manager preference (comma-separated, in order of preference)
# Linux: apt,pacman,dnf,yum,zypper,snap,flatpak
# macOS: brew,brew-cask,mas,port
PACKAGE_MANAGER_PREFERENCE=apt,snap,flatpak,pacman

# Security Settings
ALLOW_ROOT_COMMANDS=true
SAFE_MODE=false
BLOCKED_COMMANDS=rm -rf /,mkfs,dd if=/dev/zero

# Development Settings
DEBUG_MODE=false
VERBOSE_LOGGING=false
