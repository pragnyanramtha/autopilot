{
  "name": "autopilot",
  "version": "0.1.0",
  "description": "Kira - AI-powered OS automation for Linux",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "kira": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts kira",
    "start": "node dist/cli.js",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf dist/",
    "install-global": "npm run build && npm link",
    "update-deps": "./scripts/update-deps.sh"
  },
  "keywords": [
    "ai",
    "automation",
    "linux",
    "cli",
    "terminal",
    "browser"
  ],
  "author": "Pragnya Ramtha <pragnyanramtha@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pragnyanramtha/autopilot.git"
  },
  "bugs": {
    "url": "https://github.com/pragnyanramtha/autopilot/issues"
  },
  "homepage": "https://github.com/pragnyanramtha/autopilot#readme",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "genai": "^0.0.18",
    "generative-ai": "^0.1.4",
    "inquirer": "^12.0.0",
    "ora": "^8.1.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^24.16.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@types/pdf-parse": "^1.1.4",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^9.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
